# =============================================================================
# What-if Studio — Environment Configuration
# Copy to .env and fill in your credentials
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Configuration (Primary: OpenAI-compatible)
# ---------------------------------------------------------------------------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) — optional alternative
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./whatif.db
# PostgreSQL (optional — set POSTGRES_USER to enable)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=whatif

# ---------------------------------------------------------------------------
# Alternative LLM Providers
# ---------------------------------------------------------------------------
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# SiliconFlow (multi-model gateway, OpenAI-compatible)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# Zhipu GLM
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ---------------------------------------------------------------------------
# Video Generation
# ---------------------------------------------------------------------------
# HappyHorse (DashScope/Bailian) — video editing, requires source video URL
HAPPYHORSE_API_KEY=
HAPPYHORSE_BASE_URL=https://dashscope.aliyuncs.com
# Kling (Kuaishou) — text-to-video generation
KLING_API_KEY=
KLING_BASE_URL=https://api.kling.kuaishou.com
# Wan — text-to-video generation
WAN_API_KEY=
WAN_BASE_URL=
# Seedance — self-hosted / legacy video editing service
SEEDANCE_API_KEY=
SEEDANCE_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Memory (Mem0)
# ---------------------------------------------------------------------------
MEM0_API_KEY=

# ---------------------------------------------------------------------------
# Chroma Vector Store
# ---------------------------------------------------------------------------
CHROMA_PERSIST_PATH=./storage/chroma
